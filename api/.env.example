# ---- GraphOne API configuration ----

# Server
PORT=4000
NODE_ENV=development

# Data driver: "postgres" (Supabase / any Postgres) or "memory" (no DB needed, seeded in-process)
# Leave as "memory" to run instantly with zero setup; switch to "postgres" for the real DB path.
DB_DRIVER=memory

# Supabase / Postgres connection string (required when DB_DRIVER=postgres)
# Get this from Supabase: Project Settings -> Database -> Connection string -> URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# API key required for write operations (POST/PUT/DELETE) via the X-API-Key header
API_KEY=graphone-dev-key

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Trending re-rank cron interval in ms (background job). Default 5 min.
TRENDING_RERANK_INTERVAL_MS=300000

# CORS allowed origin for the web app (comma separated). "*" allows all.
CORS_ORIGIN=*
